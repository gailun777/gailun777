GATE_API_KEY=your_api_key
GATE_API_SECRET=your_api_secret

GATE_PAIR=BTC_USDT
GATE_QUOTE_AMOUNT=20
GATE_POLL_SECONDS=30

# true = 虚拟盘（推荐）; false = 实盘
GATE_PAPER_TRADING=true

# 可选: sma_cross 或 rsi
GATE_STRATEGY=sma_cross

# SMA 参数
GATE_SHORT_WINDOW=5
GATE_LONG_WINDOW=20

# RSI 参数
GATE_RSI_PERIOD=14
GATE_RSI_BUY_BELOW=30
GATE_RSI_SELL_ABOVE=70
